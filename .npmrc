# ─────────────────────────────────────────────────────────────────────────────
# .npmrc — shared npm/pnpm config
#
# npm, yarn, and bun ignore unrecognised keys, so pnpm-specific settings
# are safe to keep here. They only take effect when pnpm is used.
# ─────────────────────────────────────────────────────────────────────────────

# ── pnpm-specific ─────────────────────────────────────────────────────────────
# Automatically install peer dependencies (pnpm only)
auto-install-peers=true

# Allow packages with unmet peer deps to install without error (pnpm only)
strict-peer-dependencies=false

# Do not flatten the node_modules tree (pnpm only — keeps isolation strict)
shamefully-hoist=false

# Symlink workspace packages instead of copying (pnpm only)
link-workspace-packages=true

# Use rolling workspace protocol so changesets resolves semver correctly (pnpm only)
save-workspace-protocol=rolling
