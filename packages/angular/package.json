{
  "name": "@pdf-sign/angular",
  "version": "0.1.0",
  "description": "Angular 17+ components for @pdf-sign",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "pdfjs-dist": "^4.0.0",
    "pdf-lib": "^1.17.0"
  },
  "dependencies": {
    "@pdf-sign/core": "workspace:*"
  },
  "devDependencies": {
    "@angular/core": "^17.3.6",
    "@angular/common": "^17.3.6",
    "@angular/forms": "^17.3.6",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
