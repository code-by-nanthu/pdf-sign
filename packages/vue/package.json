{
  "name": "@pdf-sign/vue",
  "version": "1.0.0",
  "description": "Vue 3 components for @pdf-sign",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./base.css": "./dist/base.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly && cp ../tailwind-plugin/dist/base.css dist/",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "pdfjs-dist": "^4.0.0",
    "pdf-lib": "^1.17.0",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@pdf-sign/core": "workspace:*"
  },
  "devDependencies": {
    "@pdf-sign/tailwind-plugin": "workspace:*",
    "@vitejs/plugin-vue": "^5.0.4",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.11",
    "vite": "^5.2.8",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0",
    "@vue/test-utils": "^2.4.5",
    "pdfjs-dist": "^4.2.67",
    "pdf-lib": "^1.17.1"
  }
}
